<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane fx:id="scene"
            maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="-Infinity" prefHeight="400.0" prefWidth="600.0"
            xmlns="http://javafx.com/javafx/15.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="application.client.Controller">

    <children>
        <ImageView fx:id="shape1" fitWidth="40" fitHeight="40" layoutY="200" layoutX="50" />
        <Button layoutX="278.0" layoutY="26.0" mnemonicParsing="false" onAction="#start" text="Start"/>
        <Label fx:id="scoreLabel" layoutX="10" layoutY="10" text="Time: 0" />
    </children>

</AnchorPane>
